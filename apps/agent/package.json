{
  "name": "@cybergaming/agent",
  "private": true,
  "version": "0.1.0",
  "description": "Cyber Brasil Arena — agente de máquina (bloqueia/libera o PC conforme a sessão no Supabase)",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "build:win": "electron-vite build && electron-builder --win",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.110.2",
    "electron-store": "^10.0.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.0.4",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^3.0.0",
    "typescript": "^5.8.3",
    "vite": "^6.2.1"
  },
  "build": {
    "appId": "tech.cyberinformatica.arena.agent",
    "productName": "Cyber Brasil Arena Agent",
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": true,
      "runAfterFinish": true
    }
  }
}
