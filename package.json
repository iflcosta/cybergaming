{
  "name": "cybergaming",
  "private": true,
  "packageManager": "bun@1.3.11",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "format": "turbo format",
    "dev:landing": "turbo dev --filter=@cybergaming/landing",
    "dev:cliente": "turbo dev --filter=@cybergaming/cliente",
    "dev:admin": "turbo dev --filter=@cybergaming/admin"
  },
  "devDependencies": {
    "turbo": "^2.5.4"
  }
}
